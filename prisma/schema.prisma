generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions")]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                     String               @id @default(cuid())
  name                   String?
  email                  String               @unique
  emailVerified          DateTime?
  image                  String?
  passwordHash           String?
  role                   UserRole             @default(CLIENT)
  status                 UserStatus           @default(ACTIVE)
  phone                  String?
  googleId               String?              @unique
  documentType           String?
  documentNumber         String?
  passwordResetToken     String?
  passwordResetExpires   DateTime?
  vehicleType            String?
  licenseNumber          String?
  rating                 Float?               @default(0)
  totalDeliveries        Int?                 @default(0)
  pixKeyType             String?
  pixKey                 String?
  bankCode               String?
  bankName               String?
  agencyNumber           String?
  accountNumber          String?
  accountType            String?
  accountHolder          String?
  cpfCnpj                String?
  currentLatitude        Float?
  currentLongitude       Float?
  lastLocationUpdate     DateTime?
  isOnline               Boolean              @default(false)
  lastOnlineAt           DateTime?
  deliveryStatus         DeliveryPersonStatus @default(OFFLINE)
  activeOrderId          String?
  priorityScore          Int                  @default(100)
  rejectionsToday        Int                  @default(0)
  lastRejectionsReset    DateTime?
  fcmToken               String?
  fcmTokenUpdatedAt      DateTime?
  endOfDayBilling        Boolean              @default(false)
  billingPeriod          BillingPeriod?       @default(DAILY)  // Período de cobrança (dia/semana/mês)
  clientType             ClientType?          @default(NORMAL)
  clientAddress          String?
  clientLatitude         Float?
  clientLongitude        Float?
  establishmentName      String?
  establishmentAddress   String?
  establishmentNeighborhood String?  // Bairro do estabelecimento (auto-preenchido)
  establishmentCity      String?     // Cidade do estabelecimento
  establishmentState     String?     // Estado do estabelecimento
  establishmentLatitude  Float?
  establishmentLongitude Float?
  establishmentPhone     String?
  establishmentCnpj      String?
  pricingType            PricingType?         @default(POR_KM)
  fixedDeliveryFee       Float?
  emailNotificationsEnabled Boolean           @default(true)  // Habilitar/desabilitar notificações por email
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  accounts               Account[]
  auditLogs              AuditLog[]
  chatParticipations     ChatParticipant[]
  dailyReports           DailyReport[]
  emergencyAlerts        EmergencyAlert[]
  eventLogs              EventLog[]
  locationLogs           LocationLog[]
  messagesSent           Message[]            @relation("SenderMessages")
  notifications          Notification[]
  ordersAsClient         Order[]              @relation("ClientOrders")
  ordersAsDeliveryPerson Order[]              @relation("DeliveryPersonOrders")
  ordersAsEstablishment  Order[]              @relation("EstablishmentOrders")
  orderOffers            OrderOffer[]
  ratingsGiven           Rating[]             @relation("ClientRatings")
  ratingsReceived        Rating[]             @relation("DeliveryPersonRatings")
  sessions               Session[]
  withdrawals            Withdrawal[]
  neighborhoodPricings   NeighborhoodPricing[]

  @@index([email])
  @@index([deliveryStatus])
  @@index([role])
  @@index([status])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id                   String         @id @default(cuid())
  clientId             String
  deliveryPersonId     String?
  establishmentId      String?
  originAddress        String
  originLatitude       Float?
  originLongitude      Float?
  destinationAddress   String
  destinationLatitude  Float?
  destinationLongitude Float?
  notes                String?
  deliveryPhotoUrl     String?
  deliveryPhotoKey     String?
  clientPhone          String?
  orderNumber          String?        @unique  // Número único do pedido (ex: #ABC12345)
  status               OrderStatus    @default(AWAITING_PAYMENT)
  price                Float
  distance             Float
  paymentMethod        PaymentMethod?
  paymentIntentId      String?        @unique
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  acceptedAt           DateTime?
  pickedUpAt           DateTime?
  inTransitAt          DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  problemType          String?        // Tipo do problema reportado
  problemDescription   String?        // Descrição detalhada do problema
  problemReportedAt    DateTime?      // Quando o problema foi reportado
  problemResolvedAt    DateTime?      // Quando o problema foi resolvido
  auditLogs            AuditLog[]
  chat                 Chat?
  eventLogs            EventLog[]
  locationLogs         LocationLog[]
  client               User           @relation("ClientOrders", fields: [clientId], references: [id])
  deliveryPerson       User?          @relation("DeliveryPersonOrders", fields: [deliveryPersonId], references: [id])
  establishment        User?          @relation("EstablishmentOrders", fields: [establishmentId], references: [id])
  orderOffers          OrderOffer[]
  rating               Rating?
  transactions         Transaction[]

  @@index([clientId])
  @@index([deliveryPersonId])
  @@index([establishmentId])
  @@index([status])
  @@index([createdAt])
}

model Transaction {
  id              String        @id @default(cuid())
  orderId         String
  totalAmount     Float
  platformFee     Float
  deliveryFee     Float
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod
  stripePaymentId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  order           Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([paymentStatus])
}

model Rating {
  id               String   @id @default(cuid())
  orderId          String   @unique
  clientId         String
  deliveryPersonId String
  rating           Int
  comment          String?
  createdAt        DateTime @default(now())
  client           User     @relation("ClientRatings", fields: [clientId], references: [id])
  deliveryPerson   User     @relation("DeliveryPersonRatings", fields: [deliveryPersonId], references: [id])
  order            Order    @relation(fields: [orderId], references: [id])

  @@index([deliveryPersonId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  orderId   String?
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  order     Order?   @relation(fields: [orderId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([action])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Withdrawal {
  id            String           @id @default(cuid())
  userId        String
  amount        Float
  method        WithdrawalMethod
  status        WithdrawalStatus @default(PENDING)
  pixKeyType    String?
  pixKey        String?
  bankCode      String?
  bankName      String?
  agencyNumber  String?
  accountNumber String?
  accountType   String?
  accountHolder String?
  cpfCnpj       String?
  adminNotes    String?
  processedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderOffer {
  id               String              @id @default(cuid())
  orderId          String
  deliveryPersonId String
  attemptNumber    Int                 @default(1)
  status           OfferStatus         @default(PENDING)
  failureReason    OfferFailureReason?
  distanceToPickup Float
  offeredAt        DateTime            @default(now())
  expiresAt        DateTime
  respondedAt      DateTime?
  deliveryPerson   User                @relation(fields: [deliveryPersonId], references: [id])
  order            Order               @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([deliveryPersonId])
  @@index([status])
  @@index([expiresAt])
  @@index([attemptNumber])
}

model LocationLog {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?
  latitude  Float
  longitude Float
  accuracy  Float?
  speed     Float?
  heading   Float?
  isFakeGps Boolean  @default(false)
  createdAt DateTime @default(now())
  order     Order?   @relation(fields: [orderId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([createdAt])
}

model EventLog {
  id        String    @id @default(cuid())
  userId    String
  orderId   String?
  eventType EventType
  details   String?
  latitude  Float?
  longitude Float?
  accuracy  Float?
  createdAt DateTime  @default(now())
  order     Order?    @relation(fields: [orderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([orderId])
  @@index([eventType])
  @@index([createdAt])
}

model EmergencyAlert {
  id              String    @id @default(cuid())
  userId          String
  reason          String?
  latitude        Float
  longitude       Float
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isResolved])
  @@index([createdAt])
}

model Chat {
  id           String            @id @default(cuid())
  orderId      String            @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  order        Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages     Message[]

  @@index([orderId])
  @@index([createdAt])
}

model ChatParticipant {
  id         String    @id @default(cuid())
  chatId     String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
  @@index([chatId])
  @@index([userId])
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  senderId  String
  type      MessageType @default(TEXT)
  content   String
  imageUrl  String?
  imageKey  String?
  isRead    Boolean     @default(false)
  readAt    DateTime?
  createdAt DateTime    @default(now())
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User        @relation("SenderMessages", fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

model DailyReport {
  id           String    @id @default(cuid())
  userId       String
  reportDate   DateTime  @db.Date
  totalOrders  Int       @default(0)
  totalRevenue Float     @default(0)
  platformFees Float     @default(0)
  deliveryFees Float     @default(0)
  netAmount    Float     @default(0)
  orderIds     String[]
  isPaid       Boolean   @default(false)
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])

  @@unique([userId, reportDate])
  @@index([userId])
  @@index([reportDate])
  @@index([isPaid])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  fcmSent   Boolean          @default(false)
  fcmSentAt DateTime?
  fcmError  String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

model NeighborhoodPricing {
  id           String   @id @default(cuid())
  userId       String
  neighborhood String
  price        Float
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, neighborhood])
  @@index([userId])
  @@index([neighborhood])
}

enum UserRole {
  ADMIN
  CLIENT
  DELIVERY_PERSON
  ESTABLISHMENT
}

enum UserStatus {
  ACTIVE
  PENDING_APPROVAL
  BLOCKED
}

enum OrderStatus {
  AWAITING_PAYMENT
  PENDING
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  PROBLEM
  DELIVERED
  CANCELLED
  NO_COURIER_AVAILABLE
}

enum OfferFailureReason {
  TIMEOUT
  REJECTED
  SYSTEM_ERROR
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  PIX
  DEBIT_CARD
  CASH
  END_OF_DAY
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum WithdrawalMethod {
  PIX
  TED
}

enum DeliveryPersonStatus {
  OFFLINE
  ONLINE
  EM_ROTA_COLETA
  EM_ROTA_ENTREGA
  EM_EMERGENCIA
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EventType {
  STATUS_CHANGE
  LOCATION_UPDATE
  ORDER_OFFER
  ORDER_ACCEPT
  ORDER_REJECT
  CHEGADA_COLETA
  SAIDA_COLETA
  CHEGADA_ENTREGA
  ENTREGA_FINALIZADA
  PANICO_ACIONADO
  PANICO_RESOLVIDO
  GPS_FALSO_DETECTADO
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum ClientType {
  NORMAL
  DELIVERY
}

enum PricingType {
  POR_KM
  POR_BAIRRO
}

enum BillingPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum NotificationType {
  NEW_ORDER
  ORDER_ACCEPTED
  ORDER_REJECTED
  ORDER_PICKED_UP
  ORDER_DELIVERED
  ORDER_CANCELLED
  NO_DRIVER_AVAILABLE
  EMERGENCY
  DELIVERY_PROBLEM
  CHAT_MESSAGE
  ADMIN_NOTICE
  DAILY_REPORT
}


model AppSettings {
  id              String   @id @default(cuid())
  pixKeyType      String?
  pixKey          String?
  pixAccountName  String?
  platformName    String?
  supportEmail    String?
  supportPhone    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedById     String?
}
